            <column caption='Rating Score' datatype='integer' name='[Calculation_0592964103819265]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [rating]&#13;&#10;  WHEN &quot;G&quot; THEN 1&#13;&#10;  WHEN &quot;PG&quot; THEN 2&#13;&#10;  WHEN &quot;PG-13&quot; THEN 3&#13;&#10;  WHEN &quot;R&quot; THEN 4&#13;&#10;  WHEN &quot;NC-17&quot; THEN 5&#13;&#10;  WHEN &quot;TV-Y&quot; THEN 1&#13;&#10;  WHEN &quot;TV-Y7&quot; THEN 2&#13;&#10;  WHEN &quot;TV-PG&quot; THEN 3&#13;&#10;  WHEN &quot;TV-14&quot; THEN 4&#13;&#10;  WHEN &quot;TV-MA&quot; THEN 5&#13;&#10;  ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Realease Era (Dynamic)' datatype='string' name='[Calculation_0908249284947968]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [release_year] &lt; 1980 THEN &quot;Early Catalog (1920–1980)&quot;&#13;&#10;ELSEIF [release_year] &lt; 2000 THEN &quot;Pre-Streaming Era (1980–2000)&quot;&#13;&#10;ELSE &quot;Streaming Era Growth (2000–2020)&quot;&#13;&#10;END' />
